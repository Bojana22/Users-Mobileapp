<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F3E5F5"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Пријава на Студент"
    android:textSize="28sp"
    android:textStyle="bold"
    android:textColor="#4A148C"
    android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Внесете ги вашите податоци за најава"
        android:textSize="14sp"
        android:textColor="#7B1FA2"
        android:layout_marginBottom="40dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Корисничко име"
        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
        app:startIconTint="#8E24AA"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="#4A148C"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:hint="Лозинка"
        app:startIconDrawable="@android:drawable/ic_lock_lock"
        app:startIconTint="#8E24AA"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="#8E24AA"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="#4A148C"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Најави се"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#8E24AA"
        android:textColor="@android:color/white"
        app:cornerRadius="8dp" />

</LinearLayout>